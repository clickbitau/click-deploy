# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/clickdeploy

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare (optional — required for zero-touch DNS via CF Tunnel)
# Token permissions: Zone:DNS:Edit + Account:Cloudflare Tunnel:Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_ZONE_ID=

# Docker Registry (optional)
REGISTRY_URL=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
